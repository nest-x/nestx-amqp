{
  "name": "nestx-amqp",
  "version": "3.0.0",
  "description": "nestjs x amqp-connection-manager module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nest-x/nestx-amqp.git"
  },
  "author": "aquariuslt <superaquariuslt@gmail.com>",
  "license": "MIT",
  "keywords": [
    "nestjs",
    "amqp",
    "amqplib",
    "amqp-connection-manager"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "jest --forceExit --detectOpenHandles",
    "test:cov": "jest --coverage --forceExit --detectOpenHandles",
    "changeset": "changeset",
    "release": "changeset publish --access public"
  },
  "files": [
    "dist",
    "index.ts"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@golevelup/nestjs-discovery": "^6.0.0",
    "amqp-connection-manager": "^4.0.0",
    "amqplib": "^0.10.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/amqplib": "^0.10.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.0",
    "@eslint/js": "^10.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "sinon": "^21.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^6.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "<rootDir>/src/**/*.ts",
      "!<rootDir>/src/__tests__/**/*.ts",
      "!<rootDir>/src/shared/**/*.ts",
      "!<rootDir>/src/index.ts"
    ],
    "testMatch": [
      "<rootDir>/src/**/*.test.ts"
    ],
    "testEnvironment": "node",
    "coverageDirectory": "<rootDir>/reports/coverage"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
